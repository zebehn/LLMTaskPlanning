# LLM Provider API Configuration (OpenAI API compatible only)
# Copy this file to .env and fill in the values for your chosen provider

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_API_BASE=https://api.openai.com/v1  # Optional: custom endpoint

# ============================================
# vLLM Configuration (OpenAI-compatible local server)
# ============================================
# VLLM_API_KEY=EMPTY  # Usually not required for local vLLM
# VLLM_API_BASE=http://localhost:8000/v1

# ============================================
# Ollama Configuration (OpenAI-compatible local server)
# ============================================
# OLLAMA_API_KEY=ollama  # Not required, placeholder for OpenAI client
# OLLAMA_API_BASE=http://localhost:11434/v1
# WARNING: Only expose to network (0.0.0.0) if you understand the security implications

# ============================================
# LM Studio Configuration (OpenAI-compatible local server)
# ============================================
# LMSTUDIO_API_KEY=lm-studio  # Not required, placeholder for OpenAI client
# LMSTUDIO_API_BASE=http://localhost:1234/v1
# WARNING: Only expose to network (0.0.0.0) if you understand the security implications
