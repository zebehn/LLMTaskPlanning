# LLM Provider API Configuration (OpenAI API compatible only)
# Copy this file to .env and fill in the values for your chosen provider

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_API_BASE=https://api.openai.com/v1  # Optional: custom endpoint

# ============================================
# vLLM Configuration (OpenAI-compatible local server)
# ============================================
# VLLM_API_KEY=EMPTY  # Usually not required for local vLLM
# VLLM_API_BASE=http://localhost:8000/v1
